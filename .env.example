# Azure app-only client credentials (Entra ID app registration).
# Names are fixed by the spec — do not rename. All three are REQUIRED.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-client-secret-value

# Transport / runtime (optional — shown with defaults).
# mode: "stdio" (local, Claude Desktop/Code) or "http" (remote/shared).
SPDOC__TRANSPORT_MODE=stdio
SPDOC__TRANSPORT_HOST=0.0.0.0
SPDOC__TRANSPORT_PORT=8000
